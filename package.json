    "build": "node scripts/run-production-build.mjs",
    "lint": "eslint src admin server tests vite.config.ts eslint.config.js scripts/build-default-seed-db.mjs scripts/default-seed-source.mjs scripts/verify-encoding-tools.mjs scripts/verify-content-quality.mjs scripts/repair-content-quality.mjs scripts/run-production-build.mjs scripts/run-quality-gate.mjs scripts/smoke-running-server.mjs",
